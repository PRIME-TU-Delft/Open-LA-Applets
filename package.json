{
  "name": "open-la-applets",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "dev:fps": "VITE_SHOW_FPS=true vite dev",
    "build": "vite build",
    "build-netlify": "pnpx puppeteer browsers install chrome@141.0.7390.76 && BUILD_ENV=netlify vite build && BUILD_ENV=netlify tsx scripts/generate-screenshots.ts",
    "build:with-screenshots": "vite build && tsx scripts/generate-screenshots.ts",
    "preview": "vite preview",
    "screenshots": "tsx scripts/generate-screenshots.ts",
    "prepare": "svelte-kit sync || echo ''",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "format": "prettier --write .",
    "lint": "prettier --check . && eslint .",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "test": "vitest"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.1.2",
    "@eslint/compat": "^1.4.1",
    "@eslint/js": "^9.39.4",
    "@internationalized/date": "^3.12.1",
    "@lucide/svelte": "^0.515.0",
    "@storybook/addon-a11y": "^10.3.5",
    "@storybook/addon-docs": "^10.3.5",
    "@storybook/addon-svelte-csf": "^5.1.2",
    "@storybook/addon-vitest": "^10.3.5",
    "@storybook/sveltekit": "^10.3.5",
    "@svelte-put/qr": "^2.1.2",
    "@sveltejs/kit": "^2.57.1",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.2.2",
    "@types/d3": "^7.4.3",
    "@types/node": "^22.19.17",
    "@vitest/browser": "^3.2.4",
    "bits-ui": "^2.18.0",
    "clsx": "^2.1.1",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-storybook": "^10.3.5",
    "eslint-plugin-svelte": "^3.17.0",
    "globals": "^16.5.0",
    "prettier": "^3.8.3",
    "prettier-plugin-svelte": "^3.5.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "puppeteer": "24.24.1",
    "puppeteer-cluster": "^0.24.0",
    "storybook": "^10.3.5",
    "svelte": "^5.55.4",
    "svelte-check": "^4.4.6",
    "tailwind-merge": "^3.5.0",
    "tailwind-variants": "^1.0.0",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.8",
    "vitest": "^3.2.4"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ],
    "overrides": {
      "esbuild@<=0.24.2": ">=0.25.0",
      "cookie@<0.7.0": ">=0.7.0",
      "playwright@<1.55.1": ">=1.55.1",
      "devalue@<5.6.4": ">=5.6.4",
      "devalue@<=5.6.3": ">=5.6.4",
      "flatted@<3.4.0": ">=3.4.0",
      "flatted@<=3.4.1": ">=3.4.2",
      "yaml@>=1.0.0 <1.10.3": ">=1.10.3",
      "picomatch@>=4.0.0 <4.0.4": ">=4.0.4",
      "brace-expansion@<1.1.13": ">=1.1.13",
      "vite@<=6.4.1": ">=6.4.2",
      "vite@>=6.0.0 <=6.4.1": ">=6.4.2"
    }
  },
  "dependencies": {
    "@cortex-js/compute-engine": "^0.30.2",
    "@number-flow/svelte": "^0.3.13",
    "@sveltejs/adapter-netlify": "^5.2.4",
    "@sveltejs/adapter-node": "^5.5.4",
    "@threlte/core": "^8.5.9",
    "@threlte/extras": "^9.14.8",
    "@types/three": "^0.177.0",
    "d3": "^7.9.0",
    "glob": "^13.0.6",
    "katex": "^0.16.45",
    "mathlive": "^0.108.3",
    "screenfull": "^6.0.2",
    "svelte-i18n": "^4.0.1",
    "three": "^0.177.0"
  }
}
