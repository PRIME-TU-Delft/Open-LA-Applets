{
  "name": "open-la-applets",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "dev:fps": "VITE_SHOW_FPS=true vite dev",
    "build": "vite build",
    "build-netlify": "pnpx puppeteer browsers install chrome@147.0.7727.56 && BUILD_ENV=netlify vite build && BUILD_ENV=netlify tsx scripts/generate-screenshots.ts",
    "build:with-screenshots": "vite build && tsx scripts/generate-screenshots.ts",
    "preview": "vite preview",
    "screenshots": "tsx scripts/generate-screenshots.ts",
    "prepare": "svelte-kit sync || echo ''",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "format": "prettier --write .",
    "lint": "prettier --check . && eslint .",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "test": "vitest"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.1.2",
    "@eslint/compat": "^2.0.5",
    "@eslint/js": "^10.0.1",
    "@internationalized/date": "^3.12.1",
    "@lucide/svelte": "^1.14.0",
    "@storybook/addon-a11y": "^10.3.6",
    "@storybook/addon-docs": "^10.3.6",
    "@storybook/addon-svelte-csf": "^5.1.2",
    "@storybook/addon-vitest": "^10.3.6",
    "@storybook/sveltekit": "^10.3.6",
    "@svelte-put/qr": "^2.1.2",
    "@sveltejs/kit": "^2.58.0",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.2.4",
    "@types/d3": "^7.4.3",
    "@types/node": "^25.6.0",
    "@vitest/browser": "^4.1.5",
    "bits-ui": "^2.18.0",
    "clsx": "^2.1.1",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-storybook": "^10.3.6",
    "eslint-plugin-svelte": "^3.17.1",
    "globals": "^17.5.0",
    "prettier": "^3.8.3",
    "prettier-plugin-svelte": "^3.5.1",
    "prettier-plugin-tailwindcss": "^0.7.4",
    "puppeteer": "^24.42.0",
    "puppeteer-cluster": "^0.25.0",
    "storybook": "^10.3.6",
    "svelte": "^5.55.5",
    "svelte-check": "^4.4.7",
    "tailwind-merge": "^3.5.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.2.4",
    "tsx": "^4.21.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.1",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ],
    "overrides": {
      "esbuild@<=0.24.2": ">=0.25.0",
      "cookie@<0.7.0": ">=0.7.0"
    }
  },
  "dependencies": {
    "@cortex-js/compute-engine": "^0.55.6",
    "@number-flow/svelte": "^0.4.0",
    "@sveltejs/adapter-netlify": "^6.0.4",
    "@sveltejs/adapter-node": "^5.5.4",
    "@threlte/core": "^8.5.11",
    "@threlte/extras": "^9.15.0",
    "@types/three": "^0.184.0",
    "d3": "^7.9.0",
    "glob": "^13.0.6",
    "katex": "^0.16.45",
    "mathlive": "^0.109.2",
    "screenfull": "^6.0.2",
    "svelte-i18n": "^4.0.1",
    "three": "^0.184.0"
  }
}
